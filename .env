# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shared_wealth_international
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
